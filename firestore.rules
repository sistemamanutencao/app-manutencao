rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }

    function usuarioCadastrado() {
      return estaAutenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function dadosUsuario() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function usuarioAtivo() {
      return usuarioCadastrado() && dadosUsuario().ativo == true;
    }

    function perfilUsuario() {
      return usuarioAtivo() ? dadosUsuario().perfil : "colaborador";
    }

    function ehManutencao() {
      return usuarioAtivo()
        && perfilUsuario() in [
          "manutencao",
          "manutenção",
          "Manutenção",
          "MANUTENCAO",
          "MANUTENÇÃO",
          "tecnico",
          "técnico",
          "Técnico"
        ];
    }

    function ehGerencia() {
      return usuarioAtivo()
        && perfilUsuario() in [
          "gerencia",
          "gerência",
          "Gerência",
          "GERENCIA",
          "GERÊNCIA",
          "gerente",
          "gestor",
          "gestao",
          "gestão"
        ];
    }

    function podeAcompanharTodosChamados() {
      return ehManutencao() || ehGerencia();
    }

    function colaboradorExiste(codigo) {
      return codigo is string
        && codigo.size() > 0
        && exists(/databases/$(database)/documents/colaboradores/$(codigo));
    }

    function uidAutorizadoNoCodigo(codigo) {
      return estaAutenticado()
        && colaboradorExiste(codigo)
        && request.auth.uid in get(/databases/$(database)/documents/colaboradores/$(codigo)).data.uidsAutorizados;
    }

    function ehAutorChamado(dados) {
      return estaAutenticado()
        && (
          dados.criadoPorUid == request.auth.uid
          || dados.solicitanteId == request.auth.uid
          || uidAutorizadoNoCodigo(dados.colaboradorCodigo)
        );
    }

    function chamadoTemAutoriaDoUsuario() {
      return request.resource.data.criadoPorUid == request.auth.uid
        && request.resource.data.solicitanteId == request.auth.uid;
    }

    function colaboradorPodeCriarChamado() {
      return estaAutenticado()
        && chamadoTemAutoriaDoUsuario()
        && request.resource.data.status == "ABERTO"
        && uidAutorizadoNoCodigo(request.resource.data.colaboradorCodigo);
    }

    function usuarioCadastradoPodeCriarChamado() {
      return usuarioAtivo()
        && chamadoTemAutoriaDoUsuario()
        && request.resource.data.status == "ABERTO"
        && (ehManutencao() || ehGerencia());
    }

    function podeCancelarProprioChamado() {
      return estaAutenticado()
        && ehAutorChamado(resource.data)
        && resource.data.status == "ABERTO"
        && request.resource.data.status == "CANCELADO"
        && request.resource.data.criadoPorUid == resource.data.criadoPorUid
        && request.resource.data.solicitanteId == resource.data.solicitanteId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "etapaFluxo",
          "historico",
          "logs",
          "canceladoPorUid",
          "canceladoPorNome",
          "canceladoMotivo",
          "canceladoEmISO",
          "atualizadoEm"
        ]);
    }

    function usuarioPodeMarcarNotificacaoComoLida() {
      return estaAutenticado()
        && (
          resource.data.destinatarioUid == request.auth.uid
          || (ehManutencao() && resource.data.destinatarioPerfil == "manutencao")
          || (ehGerencia() && resource.data.destinatarioPerfil == "gerencia")
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lidaPorUids",
          "atualizadoEm"
        ]);
    }

    function podeCriarOuAtualizarCodigoColaborador(id) {
      return estaAutenticado()
        && request.resource.data.codigo == id
        && request.auth.uid in request.resource.data.uidsAutorizados
        && request.resource.data.keys().hasOnly([
          "codigo",
          "nome",
          "setor",
          "uidsAutorizados",
          "criadoEm",
          "atualizadoEm"
        ]);
    }

    match /chamados/{id} {
      allow read: if podeAcompanharTodosChamados() || ehAutorChamado(resource.data);
      allow create: if usuarioCadastradoPodeCriarChamado() || colaboradorPodeCriarChamado();
      allow update: if ehManutencao() || podeCancelarProprioChamado();
      allow delete: if ehManutencao();
    }

    match /colaboradores/{id} {
      allow read: if podeAcompanharTodosChamados()
        || (estaAutenticado() && request.auth.uid in resource.data.uidsAutorizados);
      allow create, update: if podeCriarOuAtualizarCodigoColaborador(id);
      allow delete: if ehManutencao();
    }

    match /planosPreventivos/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }

    match /ativos/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }

    match /comunicados/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }

    match /notificacoes/{id} {
      // Versão Spark/restaurada: notificações são internas ao app.
      // A leitura fica liberada para usuários autenticados para evitar falhas de
      // listener quando houver documentos antigos com destinatarioPerfil/destinatarioUid
      // fora do padrão atual. A interface continua filtrando por perfil/usuário.
      allow read: if estaAutenticado();

      allow create: if estaAutenticado()
        && request.resource.data.criadaPorUid == request.auth.uid
        && request.resource.data.lidaPorUids is list;

      allow update: if usuarioPodeMarcarNotificacaoComoLida() || ehManutencao();
      allow delete: if ehManutencao();
    }

    match /diagnosticos/{id} {
      allow read, create, update, delete: if ehManutencao();
    }

    match /usuarios/{id} {
      allow read: if usuarioAtivo() && (id == request.auth.uid || ehManutencao());
      allow create, update: if usuarioAtivo() && (id == request.auth.uid || ehManutencao());
      allow delete: if ehManutencao();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
