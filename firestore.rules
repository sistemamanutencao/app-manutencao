rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }

    function perfilUsuario() {
      return estaAutenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil
        : "colaborador";
    }

    function ehManutencao() {
      return estaAutenticado() && perfilUsuario() == "manutencao";
    }

    function colaboradorExiste(codigo) {
      return codigo is string
        && codigo.size() > 0
        && exists(/databases/$(database)/documents/colaboradores/$(codigo));
    }

    function uidAutorizadoNoCodigo(codigo) {
      return estaAutenticado()
        && colaboradorExiste(codigo)
        && request.auth.uid in get(/databases/$(database)/documents/colaboradores/$(codigo)).data.uidsAutorizados;
    }

    function ehAutorChamado(dados) {
      return estaAutenticado()
        && (
          dados.criadoPorUid == request.auth.uid
          || dados.solicitanteId == request.auth.uid
          || uidAutorizadoNoCodigo(dados.colaboradorCodigo)
        );
    }

    function colaboradorPodeCriarChamado() {
      return estaAutenticado()
        && request.resource.data.criadoPorUid == request.auth.uid
        && request.resource.data.solicitanteId == request.auth.uid
        && request.resource.data.status == "ABERTO"
        && uidAutorizadoNoCodigo(request.resource.data.colaboradorCodigo);
    }

    function colaboradorPodeCancelarChamado() {
      return estaAutenticado()
        && ehAutorChamado(resource.data)
        && resource.data.status == "ABERTO"
        && request.resource.data.status == "CANCELADO"
        && request.resource.data.criadoPorUid == resource.data.criadoPorUid
        && request.resource.data.solicitanteId == resource.data.solicitanteId
        && request.resource.data.colaboradorCodigo == resource.data.colaboradorCodigo
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "etapaFluxo",
          "historico",
          "canceladoPorUid",
          "canceladoPorNome",
          "canceladoMotivo",
          "canceladoEmISO",
          "atualizadoEm"
        ]);
    }

    function usuarioPodeMarcarNotificacaoComoLida() {
      return estaAutenticado()
        && resource.data.destinatarioUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lidaPorUids",
          "atualizadoEm"
        ]);
    }

    function podeCriarOuAtualizarCodigoColaborador(id) {
      return estaAutenticado()
        && request.resource.data.codigo == id
        && request.auth.uid in request.resource.data.uidsAutorizados
        && request.resource.data.keys().hasOnly([
          "codigo",
          "nome",
          "setor",
          "uidsAutorizados",
          "criadoEm",
          "atualizadoEm"
        ]);
    }

    match /chamados/{id} {
      allow read: if ehManutencao() || ehAutorChamado(resource.data);
      allow create: if ehManutencao() || colaboradorPodeCriarChamado();
      allow update: if ehManutencao() || colaboradorPodeCancelarChamado();
      allow delete: if ehManutencao();
    }

    match /colaboradores/{id} {
      allow read: if ehManutencao() || (estaAutenticado() && request.auth.uid in resource.data.uidsAutorizados);
      allow create, update: if podeCriarOuAtualizarCodigoColaborador(id);
      allow delete: if ehManutencao();
    }

    match /planosPreventivos/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }

    match /ativos/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }

    match /diagnosticosManutencao/{id} {
      allow read, create, update, delete: if ehManutencao();
    }

    match /comunicados/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }


    match /diagnosticos/{id} {
      allow read, create, update, delete: if ehManutencao();
    }

    match /notificacoes/{id} {
      allow read: if ehManutencao()
        || resource.data.destinatarioUid == request.auth.uid
        || resource.data.destinatarioPerfil == "colaborador";
      allow create: if estaAutenticado();
      allow update: if ehManutencao() || usuarioPodeMarcarNotificacaoComoLida();
      allow delete: if ehManutencao();
    }

    match /usuarios/{id} {
      allow read: if estaAutenticado() && (id == request.auth.uid || ehManutencao());
      allow create, update: if estaAutenticado() && (id == request.auth.uid || ehManutencao());
      allow delete: if ehManutencao();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
