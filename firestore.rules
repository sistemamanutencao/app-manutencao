rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }

    function perfilUsuario() {
      return estaAutenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil
        : "colaborador";
    }

    function ehManutencao() {
      return estaAutenticado() && perfilUsuario() == "manutencao";
    }

    function ehGerencia() {
      return estaAutenticado() && perfilUsuario() == "gerencia";
    }

    function podeAcompanharTodosChamados() {
      return ehManutencao() || ehGerencia();
    }

    function colaboradorExiste(codigo) {
      return codigo is string
        && codigo.size() > 0
        && exists(/databases/$(database)/documents/colaboradores/$(codigo));
    }

    function uidAutorizadoNoCodigo(codigo) {
      return estaAutenticado()
        && colaboradorExiste(codigo)
        && request.auth.uid in get(/databases/$(database)/documents/colaboradores/$(codigo)).data.uidsAutorizados;
    }

    function ehAutorChamado(dados) {
      return estaAutenticado()
        && (
          dados.criadoPorUid == request.auth.uid
          || dados.solicitanteId == request.auth.uid
          || uidAutorizadoNoCodigo(dados.colaboradorCodigo)
        );
    }

    function colaboradorPodeCriarChamado() {
      return estaAutenticado()
        && request.resource.data.criadoPorUid == request.auth.uid
        && request.resource.data.solicitanteId == request.auth.uid
        && request.resource.data.status == "ABERTO"
        && uidAutorizadoNoCodigo(request.resource.data.colaboradorCodigo);
    }

    function gerenciaPodeCriarChamado() {
      return ehGerencia()
        && request.resource.data.criadoPorUid == request.auth.uid
        && request.resource.data.solicitanteId == request.auth.uid
        && request.resource.data.status == "ABERTO";
    }

    function podeCancelarProprioChamado() {
      return estaAutenticado()
        && ehAutorChamado(resource.data)
        && resource.data.status == "ABERTO"
        && request.resource.data.status == "CANCELADO"
        && request.resource.data.criadoPorUid == resource.data.criadoPorUid
        && request.resource.data.solicitanteId == resource.data.solicitanteId
        && request.resource.data.colaboradorCodigo == resource.data.colaboradorCodigo
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "etapaFluxo",
          "historico",
          "canceladoPorUid",
          "canceladoPorNome",
          "canceladoMotivo",
          "canceladoEmISO",
          "atualizadoEm"
        ]);
    }

    function gerenciaPodeAlterarPrioridadeChamado() {
      return ehGerencia()
        && resource.data.status in ["ABERTO", "EM ANDAMENTO", "AGUARDANDO"]
        && request.resource.data.prioridade in ["Baixa", "Média", "Alta", "Crítica", "Urgente"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "prioridade",
          "prazoHoras",
          "vencimentoSLAISO",
          "slaBasePrioridade",
          "slaStatusAtual",
          "slaRecalculadoEmISO",
          "historico",
          "prioridadeAlteradaPorUid",
          "prioridadeAlteradaPorNome",
          "prioridadeAlteradaEmISO",
          "atualizadoEm"
        ]);
    }

    function usuarioPodeMarcarNotificacaoComoLida() {
      return estaAutenticado()
        && resource.data.destinatarioUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lidaPorUids",
          "atualizadoEm"
        ]);
    }

    function podeCriarOuAtualizarCodigoColaborador(id) {
      return estaAutenticado()
        && request.resource.data.codigo == id
        && request.auth.uid in request.resource.data.uidsAutorizados
        && request.resource.data.keys().hasOnly([
          "codigo",
          "nome",
          "setor",
          "uidsAutorizados",
          "criadoEm",
          "atualizadoEm"
        ]);
    }



    function camposCadastroColaboradorValidos() {
      return request.resource.data.keys().hasOnly([
          "emailKey",
          "codigoColaborador",
          "nome",
          "email",
          "setor",
          "perfil",
          "ativo",
          "status",
          "criadoPorUid",
          "criadoPorNome",
          "criadoEm",
          "atualizadoEm"
        ])
        && request.resource.data.emailKey is string
        && request.resource.data.codigoColaborador is string
        && request.resource.data.nome is string
        && request.resource.data.email is string
        && request.resource.data.setor is string
        && request.resource.data.perfil == "colaborador"
        && request.resource.data.ativo is bool
        && request.resource.data.status in ["pendente", "inativo"];
    }

    function manutencaoPodeSalvarCadastroColaborador() {
      return ehManutencao() && camposCadastroColaboradorValidos();
    }

    function cadastroColaboradorPendenteValido(emailKey) {
      return estaAutenticado()
        && request.auth.token.email is string
        && emailKey is string
        && exists(/databases/$(database)/documents/cadastrosColaboradores/$(emailKey))
        && get(/databases/$(database)/documents/cadastrosColaboradores/$(emailKey)).data.email == request.auth.token.email
        && get(/databases/$(database)/documents/cadastrosColaboradores/$(emailKey)).data.status == "pendente"
        && get(/databases/$(database)/documents/cadastrosColaboradores/$(emailKey)).data.ativo == true
        && get(/databases/$(database)/documents/cadastrosColaboradores/$(emailKey)).data.perfil == "colaborador";
    }

    function usuarioPrimeiroAcessoColaboradorValido(id) {
      return estaAutenticado()
        && id == request.auth.uid
        && request.auth.token.email is string
        && request.resource.data.keys().hasOnly([
          "nome",
          "email",
          "setor",
          "unidade",
          "perfil",
          "ativo",
          "origem",
          "cadastroColaboradorEmailKey",
          "colaboradorCodigo",
          "criadoEm",
          "atualizadoEm"
        ])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.perfil == "colaborador"
        && request.resource.data.ativo == true
        && request.resource.data.cadastroColaboradorEmailKey is string
        && request.resource.data.colaboradorCodigo is string
        && cadastroColaboradorPendenteValido(request.resource.data.cadastroColaboradorEmailKey);
    }

    function colaboradorPodeConcluirCadastro() {
      return estaAutenticado()
        && request.auth.token.email is string
        && request.auth.token.email == resource.data.email
        && resource.data.status == "pendente"
        && request.resource.data.status == "concluido"
        && request.resource.data.uidCriado == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "uidCriado",
          "concluidoEm",
          "atualizadoEm"
        ]);
    }

    function usuarioPodeAtualizarProprioCadastroBasico(id) {
      return estaAutenticado()
        && id == request.auth.uid
        && resource.data.perfil == request.resource.data.perfil
        && resource.data.ativo == request.resource.data.ativo
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "nome",
          "setor",
          "atualizadoEm"
        ]);
    }

    match /chamados/{id} {
      allow read: if podeAcompanharTodosChamados() || ehAutorChamado(resource.data);
      allow create: if ehManutencao() || gerenciaPodeCriarChamado() || colaboradorPodeCriarChamado();
      allow update: if ehManutencao() || podeCancelarProprioChamado() || gerenciaPodeAlterarPrioridadeChamado();
      allow delete: if ehManutencao();
    }

    match /colaboradores/{id} {
      allow read: if podeAcompanharTodosChamados() || (estaAutenticado() && request.auth.uid in resource.data.uidsAutorizados);
      allow create, update: if podeCriarOuAtualizarCodigoColaborador(id);
      allow delete: if ehManutencao();
    }

    match /planosPreventivos/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }

    match /ativos/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }

    match /comunicados/{id} {
      allow read: if estaAutenticado();
      allow create, update, delete: if ehManutencao();
    }

    match /notificacoes/{id} {
      allow read: if podeAcompanharTodosChamados()
        || resource.data.destinatarioUid == request.auth.uid
        || resource.data.destinatarioPerfil == "colaborador";
      allow create: if estaAutenticado();
      allow update: if ehManutencao() || usuarioPodeMarcarNotificacaoComoLida();
      allow delete: if ehManutencao();
    }


    match /cadastrosColaboradores/{id} {
      allow read: if ehManutencao()
        || (estaAutenticado() && request.auth.token.email is string && resource.data.email == request.auth.token.email);
      allow create, update: if manutencaoPodeSalvarCadastroColaborador() || colaboradorPodeConcluirCadastro();
      allow delete: if ehManutencao();
    }

    match /diagnosticos/{id} {
      allow read, create, update, delete: if ehManutencao();
    }

    match /usuarios/{id} {
      allow read: if estaAutenticado() && (id == request.auth.uid || ehManutencao());
      allow create: if ehManutencao() || usuarioPrimeiroAcessoColaboradorValido(id);
      allow update: if ehManutencao() || usuarioPodeAtualizarProprioCadastroBasico(id);
      allow delete: if ehManutencao();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
