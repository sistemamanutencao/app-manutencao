rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function estaAutenticado() {
      return request.auth != null;
    }

    function perfilUsuario() {
      return estaAutenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil
        : "colaborador";
    }

    function usuarioAtivo() {
      return estaAutenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.ativo == true;
    }

    function ehAdministrador() {
      return usuarioAtivo() && perfilUsuario() == "administrador";
    }

    function ehManutencao() {
      return usuarioAtivo() && perfilUsuario() == "manutencao";
    }

    function ehGerencia() {
      return usuarioAtivo() && perfilUsuario() == "gerencia";
    }

    function podeAcompanharTodosChamados() {
      return ehAdministrador() || ehManutencao() || ehGerencia();
    }

    function ehAutorChamado(dados) {
      return usuarioAtivo()
        && (
          dados.criadoPorUid == request.auth.uid
          || dados.solicitanteId == request.auth.uid
        );
    }

    function usuarioPodeCriarChamado() {
      return usuarioAtivo()
        && request.resource.data.criadoPorUid == request.auth.uid
        && request.resource.data.solicitanteId == request.auth.uid
        && request.resource.data.status == "ABERTO";
    }

    function podeCancelarProprioChamado() {
      return usuarioAtivo()
        && ehAutorChamado(resource.data)
        && resource.data.status == "ABERTO"
        && request.resource.data.status == "CANCELADO"
        && request.resource.data.criadoPorUid == resource.data.criadoPorUid
        && request.resource.data.solicitanteId == resource.data.solicitanteId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "etapaFluxo",
          "historico",
          "canceladoPorUid",
          "canceladoPorNome",
          "canceladoMotivo",
          "canceladoEmISO",
          "atualizadoEm"
        ]);
    }

    function usuarioPodeMarcarNotificacaoComoLida() {
      return usuarioAtivo()
        && resource.data.destinatarioUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lidaPorUids",
          "atualizadoEm"
        ]);
    }

    match /chamados/{id} {
      allow read: if podeAcompanharTodosChamados() || ehAutorChamado(resource.data);
      allow create: if usuarioPodeCriarChamado();
      allow update: if ehManutencao() || ehAdministrador() || podeCancelarProprioChamado();
      allow delete: if ehAdministrador() || ehManutencao();
    }

    match /planosPreventivos/{id} {
      allow read: if usuarioAtivo();
      allow create, update, delete: if ehManutencao();
    }

    match /ativos/{id} {
      allow read: if usuarioAtivo();
      allow create, update, delete: if ehManutencao();
    }

    match /comunicados/{id} {
      allow read: if usuarioAtivo();
      allow create, update, delete: if ehManutencao();
    }

    match /notificacoes/{id} {
      allow read: if podeAcompanharTodosChamados()
        || resource.data.destinatarioUid == request.auth.uid
        || resource.data.destinatarioPerfil == "colaborador";
      allow create: if usuarioAtivo();
      allow update: if ehManutencao() || ehAdministrador() || usuarioPodeMarcarNotificacaoComoLida();
      allow delete: if ehAdministrador() || ehManutencao();
    }

    match /diagnosticos/{id} {
      allow read, create, update, delete: if ehManutencao();
    }

    match /usuarios/{id} {
      allow read: if usuarioAtivo() && (id == request.auth.uid || ehAdministrador());
      allow create, update, delete: if ehAdministrador();
    }

    // Coleção mantida apenas para compatibilidade com versões anteriores.
    // O novo fluxo usa usuarios/{uid} e login por e-mail/senha para todos os perfis.
    match /colaboradores/{id} {
      allow read, write: if ehAdministrador();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
